# Copy to .env beside this file and adjust.

# Host port mappings (container listens on the same ports via WEB_PORT / WS_PORT env)
WEB_PORT=4002
WS_PORT=4001
PCM_RELAY_PORT=4100

# Host folder bind-mounted to /usr/src/app (seeded from image on first run)
APP_DATA=./appdata

# Optional: override paths inside the container (defaults in config.json use ./storage and ./logs)
# STORAGE_DIR=./storage
# DEBUG_LOG_DIR=./logs

# GHCR image (replace OWNER/REPO with your GitHub org/repo, lowercase)
# IMAGE=ghcr.io/owner/collabfm:latest
